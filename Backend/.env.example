DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/parkandgo
SECRET_KEY=your-secret-key-here-change-in-production
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
REDIS_URL=redis://localhost:6379

# CORS — comma-separated list of allowed frontend origins (no trailing slashes)
# Local dev:      ALLOWED_ORIGINS=http://localhost:3000
# Production:     ALLOWED_ORIGINS=https://parkango.netlify.app
# Both:           ALLOWED_ORIGINS=https://parkango.netlify.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

ADMIN_EMAILS=your-admin-email@example.com

# Set to "production" and DEBUG=false on Render
ENVIRONMENT=development
DEBUG=true

